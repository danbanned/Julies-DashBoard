# Copy to .env (or .env.local) and fill in.
# Maps: docs/GOOGLE_MAPS.md · Calendar: docs/GOOGLE_CALENDAR.md · Alerts: docs/NOTIFICATIONS.md
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
DATABASE_URL=
DIRECT_URL=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# 64 hex chars — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
NEXT_PUBLIC_NTFY_TOPIC=
# Web Push (docs/WEB_PUSH.md): npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# random secret; n8n sends it as the x-push-secret header
PUSH_SEND_SECRET=
# Auth.js session signing secret: npx auth secret (or any random base64)
AUTH_SECRET=
# CRM sheet sync (docs/CRM_PIPELINE.md): n8n sends this as x-crm-secret
CRM_SYNC_SECRET=
